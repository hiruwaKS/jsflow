00019|         "sink_hqbpillvul_shelljs_exec",
00020|     ],
00021|     # XSS sinks (http response emission)
00022|     # - sink_hqbpillvul_* are modeled sinks used by builtin stubs
00023|     # - res.send/write/end are common Express/Node patterns that may appear
00024|     #   as dummy function names in graphs when the response object is a wildcard
00025|     "xss": [
00026|         "sink_hqbpillvul_http_write",
00027|         "sink_hqbpillvul_http_setHeader",
00028|         "res.send",
00029|         "res.write",
00030|         "res.end",
00031|     ],
00032|     # Prototype pollution "goal" function names used by rough call graph pruning.
00033|     # This list is intentionally broad: real-world prototype pollution commonly
00034|     # flows through deep-merge / deep-set helpers rather than explicit writes
00035|     # to built-in prototypes.
00036|     "proto_pollution": [
00037|         "merge",
00038|         "extend",
00039|         "assign",
00040|         "defaultsDeep",
00041|         "defaultsdeep",
00042|         "set",
00043|         "setWith",
00044|         "setwith",
00045|         "clone",
00046|         "parse",
00047|     ],
00048|     "code_exec": [
00049|         "Function",
00050|         "eval",
00051|         # "sink_hqbpillvul_execFile",
00052|         # 'sink_hqbpillvul_exec',
00053|         # 'sink_hqbpillvul_execSync',
00054|         "sink_hqbpillvul_eval",
00055|     ],
00056|     # NoSQL sinks. In modeled MongoDB stubs we emit sink_hqbpillvul_nosql; in
00057|     # simple samples (e.g. tests) the query API can show up directly as `find`.
00058|     "nosql": ["sink_hqbpillvul_nosql", "find"],
00059|     "sanitation": ["parseInt"],
00060|     # Path traversal sinks: either modeled sinks or direct fs read calls.
00061|     "path_traversal": [
00062|         "pipe",
00063|         "sink_hqbpillvul_http_write",
00064|         "sink_hqbpillvul_fs_read",
00065|         "fs.readFile",
00066|         "fs.readFileSync",
00067|     ],
00068| }
