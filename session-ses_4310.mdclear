  "content": "import unittest\nfrom jsflow.constraints.conditions import (\n    Condition, TrueCondition, FalseCondition, Predicate,\n    NamedCondition, NotCondition, AndCondition, OrCondition, PathConstraint\n)\nfrom jsflow.constraints.expressions import (\n    Expression, ConstString, ConstNumber, Symbol, Concat, Add, Sub,\n    Choice, UnknownOp, _leaf_expr, _group_contributors, _op_to_expr\n)\n\n\nclass TestConditionClasses(unittest.TestCase):\n    \"\"\"Test all condition classes.\"\"\"\n\n    def test_true_condition(self):\n        cond = TrueCondition()\n        self.assertIsInstance(cond, Condition)\n\n    def test_false_condition(self):\n        cond = FalseCondition()\n        self.assertIsInstance(cond, Condition)\n\n    def test_predicate_basic(self):\n        pred = Predicate(op=\"eq\", left=\"x\", right=\"y\")\n        self.assertEqual(pred.op, \"eq\")\n        self.assertEqual(pred.left, \"x\")\n        self.assertEqual(pred.right, \"y\")\n\n    def test_predicate_with_expression(self):\n        left_expr = ConstString(value=\"hello\", tainted=False)\n        right_expr = ConstString(value=\"world\", tainted=False)\n        pred = Predicate(op=\"contains\", left=left_expr, right=right_expr)\n        self.assertIsInstance(pred.left, ConstString)\n        self.assertIsInstance(pred.right, ConstString)\n\n    def test_predicate_without_right(self):\n        pred = Predicate(op=\"exists\", left=\"x\")\n        self.assertIsNone(pred.right)\n\n    def test_named_condition(self):\n        cond = NamedCondition(name=\"guard_check\")\n        self.assertEqual(cond.name, \"guard_check\")\n\n    def test_not_condition(self):\n        inner = TrueCondition()\n        cond = NotCondition(inner=inner)\n        self.assertEqual(cond.inner, inner)\n\n    def test_and_condition(self):\n        parts = [TrueCondition(), FalseCondition()]\n        cond = AndCondition(parts=parts)\n        self.assertEqual(len(cond.parts), 2)\n\n    def test_and_condition_empty(self):\n        cond = AndCondition()\n        self.assertEqual(len(cond.parts), 0)\n\n    def test_or_condition(self):\n        parts = [TrueCondition(), FalseCondition()]\n        cond = OrCondition(parts=parts)\n        self.assertEqual(len(cond.parts), 2)\n\n    def test_path_constraint(self):\n        expr = ConstString(value=\"test\", tainted=False)\n        cond = TrueCondition()\n        pc = PathConstraint(expr=expr, condition=cond)\n        self.assertEqual(pc.expr, expr)\n        self.assertEqual(pc.condition, cond)\n\n    def test_path_constraint_with_and_condition(self):\n        expr = ConstNumber(value=42.0, tainted=True)\n        cond = AndCondition(parts=[TrueCondition(), FalseCondition()])\n        pc = PathConstraint(expr=expr, condition=cond)\n        self.assertIsInstance(pc.expr, ConstNumber)\n\n\nclass TestExpressionClassesExtended(unittest.TestCase):\n    \"\"\"Extended tests for expression classes.\"\"\"\n\n    def test_const_string_full(self):\n        expr = ConstString(value=\"full test\", tainted=True)\n        self.assertEqual(expr.value, \"full test\")\n        self.assertTrue(expr.tainted)\n\n    def test_const_number_full(self):\n        expr = ConstNumber(value=3.14159, tainted=False)\n        self.assertEqual(expr.value, 3.14159)\n        self.assertFalse(expr.tainted)\n\n    def test_symbol_with_type_hint(self):\n        expr = Symbol(node_id=\"test123\", type_hint=\"object\", tainted=True)\n        self.assertEqual(expr.node_id, \"test123\")\n        self.assertEqual(expr.type_hint, \"object\")\n        self.assertTrue(expr.tainted)\n\n    def test_concat_multiple_parts(self):\n        parts = [\n            ConstString(\"a\", tainted=False),\n            ConstString(\"b\", tainted=False),\n            ConstString(\"c\", tainted=False),\n        ]\n        expr = Concat(parts=parts, tainted=True)\n        self.assertEqual(len(expr.parts), 3)\n        self.assertTrue(expr.tainted)\n\n    def test_add_multiple_terms(self):\n        terms = [\n            ConstNumber(1.0, tainted=False),\n            ConstNumber(2.0, tainted=False),\n            ConstNumber(3.0, tainted=False),\n        ]\n        expr = Add(terms=terms, tainted=True)\n        self.assertEqual(len(expr.terms), 3)\n        self.assertTrue(expr.tainted)\n\n    def test_sub_left_right(self):\n        left = ConstNumber(10.0, tainted=False)\n        right = ConstNumber(3.0, tainted=False)\n        expr = Sub(left=left, right=right, tainted=True)\n        self.assertEqual(expr.left.value, 10.0)\n        self.assertEqual(expr.right.value, 3.0)\n\n    def test_sub_defaults(self):\n        expr = Sub()\n        self.assertIsNone(expr.left)\n        self.assertIsNone(expr.right)\n        self.assertFalse(expr.tainted)\n\n    def test_choice_multiple_options(self):\n        options = [\n            ConstString(\"opt1\", tainted=False),\n            ConstString(\"opt2\", tainted=False),\n            ConstString(\"opt3\", tainted=False),\n        ]\n        expr = Choice(options=options, tainted=True)\n        self.assertEqual(len(expr.options), 3)\n        self.assertTrue(expr.tainted)\n\n    def test_unknown_op_with_args(self):\n        args = [\n            ConstString(\"arg1\", tainted=False),\n            ConstNumber(42.0, tainted=False),\n        ]\n        expr = UnknownOp(op=\"custom_op\", args=args, tainted=False)\n        self.assertEqual(expr.op, \"custom_op\")\n        self.assertEqual(len(expr.args), 2)\n\n\nclass TestLeafExprExtended(unittest.TestCase):\n    \"\"\"Extended tests for _leaf_expr function.\"\"\"\n\n    def test_leaf_expr_string_literal(self):\n        expr = _leaf_expr(\"node1\", \"string\", \"hello world\", False)\n        self.assertIsInstance(expr, ConstString)\n        self.assertEqual(expr.value, \"hello world\")\n        self.assertFalse(expr.tainted)\n\n    def test_leaf_expr_number_literal(self):\n        expr = _leaf_expr(\"node2\", \"number\", \"123.45\", True)\n        self.assertIsInstance(expr, ConstNumber)\n        self.assertEqual(expr.value, 123.45)\n        self.assertTrue(expr.tainted)\n\n    def test_leaf_expr_number_invalid(self):\n        expr = _leaf_expr(\"node3\", \"number\", \"not_a_number\", False)\n        self.assertIsInstance(expr, Symbol)\n        self.assertEqual(expr.node_id, \"node3\")\n        self.assertEqual(expr.type_hint, \"number\")\n\n    def test_leaf_expr_wildcard_string(self):\n        from jsflow.utils.utilities import wildcard\n        expr = _leaf_expr(\"node4\", \"string\", wildcard, False)\n        self.assertIsInstance(expr, Symbol)\n        self.assertEqual(expr.node_id, \"node4\")\n\n    def test_leaf_expr_wildcard_number(self):\n        from jsflow.utils.utilities import wildcard\n        expr = _leaf_expr(\"node5\", \"number\", wildcard, False)\n        self.assertIsInstance(expr, Symbol)\n        self.assertEqual(expr.node_id, \"node5\")\n\n    def test_leaf_expr_none_value(self):\n        expr = _leaf_expr(\"node6\", \"string\", None, False)\n        self.assertIsInstance(expr, Symbol)\n        self.assertEqual(expr.node_id, \"node6\")\n\n    def test_leaf_expr_object_type(self):\n        expr = _leaf_expr(\"node7\", \"object\", \"some_value\", True)\n        self.assertIsInstance(expr, Symbol)\n        self.assertEqual(expr.node_id, \"node7\")\n        self.assertEqual(expr.type_hint, \"object\")\n        self.assertTrue(expr.tainted)\n\n\nclass TestGroupContributorsExtended(unittest.TestCase):\n    \"\"\"Extended tests for _group_contributors function.\"\"\"\n\n    def test_empty_in_edges(self):\n        result = _group_contributors([])\n        self.assertEqual(result, {})\n\n    def test_single_contributor(self):\n        in_edges = [\n            (\"src1\", \"dst\", {\"opt\": (\"string_concat\", \"group1\", 0)}),\n        ]\n        result = _group_contributors(in_edges)\n        self.assertIn((\"string_concat\", \"group1\"), result)\n        self.assertEqual(len(result[(\"string_concat\", \"group1\")]), 1)\n\n    def test_multiple_groups(self):\n        in_edges = [\n            (\"src1\", \"dst\", {\"opt\": (\"string_concat\", \"group1\", 0)}),\n            (\"src2\", \"dst\", {\"opt\": (\"string_concat\", \"group1\", 1)}),\n            (\"src3\", \"dst\", {\"opt\": (\"numeric_add\", \"group2\", 0)}),\n        ]\n        result = _group_contributors(in_edges)\n        self.assertEqual(len(result), 2)\n        self.assertIn((\"string_concat\", \"group1\"), result)\n        self.assertIn((\"numeric_add\", \"group2\"), result)\n\n    def test_missing_opt_key(self):\n        in_edges = [\n            (\"src1\", \"dst\", {\"type\": \"edge\"}),\n            (\"src2\", \"dst\", {\"other\": \"data\"}),\n        ]\n        result = _group_contributors(in_edges)\n        self.assertIn((\"unknown\", \"none\"), result)\n        self.assertEqual(len(result[(\"unknown\", \"none\")]), 2)\n\n    def test_partial_opt_tuple(self):\n        in_edges = [\n            (\"src1\", \"dst\", {\"opt\": (\"op1\",)}),\n            (\"src2\", \"dst\", {\"opt\": (\"op1\", \"groupA\")}),\n            (\"src3\", \"dst\", {\"opt\": (\"op1\", \"groupA\", 0)}),\n        ]\n        result = _group_contributors(in_edges)\n        # Should handle partial opt tuples gracefully\n        self.assertIn((\"op1\", \"groupA\"), result)\n\n    def test_none_opt(self):\n        in_edges = [\n            (\"src1\", \"dst\", {\"opt\": None}),\n        ]\n        result = _group_contributors(in_edges)\n        self.assertIn((\"unknown\", \"none\"), result)\n\n    def test_empty_opt_tuple(self):\n        in_edges = [\n            (\"src1\", \"dst\", {\"opt\": ()}),\n        ]\n        result = _group_contributors(in_edges)\n        self.assertIn((\"unknown\", \"none\"), result)\n\n\nclass TestOpToExprExtended(unittest.TestCase):\n    \"\"\"Extended tests for _op_to_expr function.\"\"\"\n\n    def test_string_concat(self):\n        args = [\n            ConstString(\"a\", tainted=False),\n            ConstString(\"b\", tainted=False),\n            ConstString(\"c\", tainted=False),\n        ]\n        expr = _op_to_expr(\"string_concat\", args, True)\n        self.assertIsInstance(expr, Concat)\n        self.assertEqual(len(expr.parts), 3)\n        self.assertTrue(expr.tainted)\n\n    def test_numeric_add(self):\n        args = [\n            ConstNumber(1.0, tainted=False),\n            ConstNumber(2.0, tainted=False),\n        ]\n        expr = _op_to_expr(\"numeric_add\", args, False)\n        self.assertIsInstance(expr, Add)\n        self.assertEqual(len(expr.terms), 2)\n        self.assertFalse(expr.tainted)\n\n    def test_unknown_add(self):\n        args = [\n            ConstString(\"a\", tainted=False),\n            ConstString(\"b\", tainted=False),\n        ]\n        expr = _op_to_expr(\"unknown_add\", args, True)\n        self.assertIsInstance(expr, Choice)\n        self.assertEqual(len(expr.options), 2)\n\n    def test_sub_two_args(self):\n        args = [\n            ConstNumber(10.0, tainted=False),\n            ConstNumber(3.0, tainted=False),\n        ]\n        expr = _op_to_expr(\"sub\", args, False)\n        self.assertIsInstance(expr, Sub)\n        self.assertEqual(expr.left.value, 10.0)\n        self.assertEqual(expr.right.value, 3.0)\n\n    def test_sub_single_arg(self):\n        args = [ConstNumber(10.0, tainted=False)]\n        expr = _op_to_expr(\"sub\", args, False)\n        self.assertIsInstance(expr, Sub)\n        self.assertEqual(expr.left.value, 10.0)\n\n    def test_sub_three_args(self):\n        args = [\n            ConstNumber(10.0, tainted=False),\n            ConstNumber(3.0, tainted=False),\n            ConstNumber(2.0, tainted=False),\n        ]\n        expr = _op_to_expr(\"sub\", args, False)\n        self.assertIsInstance(expr, Sub)\n        # Should use left-associative with nested Add\n        self.assertIsInstance(expr.right, Add)\n\n    def test_array_join(self):\n        args = [\n            ConstString(\"a\", tainted=False),\n            ConstString(\"b\", tainted=False),\n        ]\n        expr = _op_to_expr(\"array_join\", args, False)\n        self.assertIsInstance(expr, Concat)\n\n    def test_unknown_op(self):\n        args = [ConstString(\"x\", tainted=False)]\n        expr = _op_to_expr(\"completely_custom_op\", args, True)\n        self.assertIsInstance(expr, UnknownOp)\n        self.assertEqual(expr.op, \"completely_custom_op\")\n\n    def test_none_op(self):\n        args = [ConstString(\"x\", tainted=False)]\n        expr = _op_to_expr(None, args, False)\n        self.assertIsInstance(expr, UnknownOp)\n        self.assertEqual(expr.op, \"unknown\")\n\n    def test_empty_args(self):\n        expr = _op_to_expr(\"string_concat\", [], False)\n        self.assertIsInstance(expr, Concat)\n        self.assertEqual(len(expr.parts), 0)\n\n\nif __name__ == \"__main__\":\n    unittest.main()\n"
}
