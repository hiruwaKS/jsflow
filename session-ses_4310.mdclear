  "content": "import unittest\nfrom unittest.mock import MagicMock, Mock, patch\nimport sys\nimport os\n\nsys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))\n\nfrom jsflow.models.modeled_builtin_modules import (\n    get_module, setup_fs, setup_util, setup_path,\n    read_file, read_file_sync, util_format, path_join,\n    modeled_modules\n)\nfrom jsflow.utils.utilities import NodeHandleResult, wildcard\n\n\nclass MockGraph:\n    \"\"\"Mock Graph class for testing builtin modules.\"\"\"\n\n    def __init__(self):\n        self.builtin_modules = {}\n        self.null_obj = 0\n        self.cur_file_path = \"/test\"\n\n    def add_obj_node(self, caller_ast=None, js_type=None, code=None):\n        obj_id = len(getattr(self, '_obj_count', []))\n        setattr(self, '_obj_count', getattr(self, '_obj_count', []) + [obj_id])\n        return obj_id\n\n    def add_blank_func_as_prop(self, name, module, handler):\n        pass\n\n    def add_blank_func_with_og_nodes(self, name):\n        return len(getattr(self, '_func_count', []))\n\n    def set_node_attr(self, node, attr):\n        if not hasattr(self, '_node_attrs'):\n            self._node_attrs = {}\n        if node not in self._node_attrs:\n            self._node_attrs[node] = {}\n        self._node_attrs[node][attr[0]] = attr[1]\n\n    def get_node_attr(self, node):\n        if hasattr(self, '_node_attrs') and node in self._node_attrs:\n            return self._node_attrs[node]\n        return {}\n\n    def get_cur_file_path(self):\n        return self.cur_file_path\n\n\nclass TestGetModule(unittest.TestCase):\n    def test_get_module_existing(self):\n        \"\"\"Test get_module with existing modeled module.\"\"\"\n        G = MockGraph()\n        G.builtin_modules['fs'] = 123  # Pre-populate\n\n        result = get_module(G, 'fs')\n        self.assertEqual(result, 123)\n\n    def test_get_module_not_modeled(self):\n        \"\"\"Test get_module with non-modeled module.\"\"\"\n        G = MockGraph()\n\n        result = get_module(G, 'nonexistent_module')\n        self.assertIsNone(result)\n\n\nclass TestSetupFs(unittest.TestCase):\n    def test_setup_fs_returns_module(self):\n        \"\"\"Test that setup_fs creates a module with fs functions.\"\"\"\n        G = MockGraph()\n\n        result = setup_fs(G)\n\n        self.assertIsNotNone(result)\n        self.assertIn('fs', G.builtin_modules)\n\n\nclass TestReadFileSync(unittest.TestCase):\n    def test_read_file_sync_basic(self):\n        \"\"\"Test basic read_file_sync functionality.\"\"\"\n        G = MockGraph()\n\n        # Mock the file operations\n        with patch('builtins.open', create=True) as mock_open:\n            mock_file = MagicMock()\n            mock_file.read.return_value = \"file content\"\n            mock_file.__enter__ = Mock(return_value=mock_file)\n            mock_file.__exit__ = Mock(return_value=False)\n            mock_open.return_value = mock_file\n\n            with patch('os.path.exists', return_value=True):\n                with patch('os.path.normpath', return_value=\"/test/file.js\"):\n                    result = read_file_sync(G, None, None, None, NodeHandleResult(obj_nodes=[1]))\n\n    def test_read_file_sync_wildcard_path(self):\n        \"\"\"Test read_file_sync with wildcard path.\"\"\"\n        G = MockGraph()\n\n        path_result = NodeHandleResult(obj_nodes=[1])\n        # Simulate wildcard value\n        G.set_node_attr(1, ('code', wildcard))\n\n        result = read_file_sync(G, None, None, None, path_result)\n        self.assertIsInstance(result, NodeHandleResult)\n\n\nclass TestSetupUtil(unittest.TestCase):\n    def test_setup_util_returns_module(self):\n        \"\"\"Test that setup_util creates a module with util functions.\"\"\"\n        G = MockGraph()\n\n        result = setup_util(G)\n\n        self.assertIsNotNone(result)\n        self.assertIn('util', G.builtin_modules)\n\n\nclass TestUtilFormat(unittest.TestCase):\n    def test_util_format_basic(self):\n        \"\"\"Test basic util_format functionality.\"\"\"\n        G = MockGraph()\n\n        fmt_result = NodeHandleResult(obj_nodes=[G.add_obj_node(None, \"string\", \"Hello %s\")])\n        arg_result = NodeHandleResult(obj_nodes=[G.add_obj_node(None, \"string\", \"World\")])\n\n        result = util_format(G, None, None, None, fmt_result, arg_result)\n\n        self.assertIsInstance(result, NodeHandleResult)\n\n    def test_util_format_wildcard_format(self):\n        \"\"\"Test util_format with wildcard format string.\"\"\"\n        G = MockGraph()\n\n        fmt_result = NodeHandleResult(obj_nodes=[G.add_obj_node(None, \"string\", wildcard)])\n        arg_result = NodeHandleResult(obj_nodes=[G.add_obj_node(None, \"string\", \"test\")])\n\n        result = util_format(G, None, None, None, fmt_result, arg_result)\n\n        self.assertIsInstance(result, NodeHandleResult)\n\n    def test_util_format_no_format_specifier(self):\n        \"\"\"Test util_format with no format specifiers.\"\"\"\n        G = MockGraph()\n\n        fmt_result = NodeHandleResult(obj_nodes=[G.add_obj_node(None, \"string\", \"Hello World\")])\n        arg_result = NodeHandleResult(obj_nodes=[G.add_obj_node(None, \"string\", \"extra\")])\n\n        result = util_format(G, None, None, None, fmt_result, arg_result)\n\n        self.assertIsInstance(result, NodeHandleResult)\n\n\nclass TestSetupPath(unittest.TestCase):\n    def test_setup_path_returns_module(self):\n        \"\"\"Test that setup_path creates a module with path functions.\"\"\"\n        G = MockGraph()\n\n        result = setup_path(G)\n\n        self.assertIsNotNone(result)\n        self.assertIn('path', G.builtin_modules)\n\n\nclass TestPathJoin(unittest.TestCase):\n    def test_path_join_basic(self):\n        \"\"\"Test basic path_join functionality.\"\"\"\n        G = MockGraph()\n\n        path1 = NodeHandleResult(obj_nodes=[G.add_obj_node(None, \"string\", \"home\")])\n        path2 = NodeHandleResult(obj_nodes=[G.add_obj_node(None, \"string\", \"user\")])\n\n        result = path_join(G, None, None, None, path1, path2)\n\n        self.assertIsInstance(result, NodeHandleResult)\n\n    def test_path_join_single_path(self):\n        \"\"\"Test path_join with single path component.\"\"\"\n        G = MockGraph()\n\n        path1 = NodeHandleResult(obj_nodes=[G.add_obj_node(None, \"string\", \"home\")])\n\n        result = path_join(G, None, None, None, path1)\n\n        self.assertIsInstance(result, NodeHandleResult)\n\n    def test_path_join_wildcard(self):\n        \"\"\"Test path_join with wildcard path.\"\"\"\n        G = MockGraph()\n\n        path1 = NodeHandleResult(obj_nodes=[G.add_obj_node(None, \"string\", wildcard)])\n\n        result = path_join(G, None, None, None, path1)\n\n        self.assertIsInstance(result, NodeHandleResult)\n\n\nclass TestModeledModules(unittest.TestCase):\n    def test_modeled_modules_dict(self):\n        \"\"\"Test that modeled_modules contains expected modules.\"\"\"\n        self.assertIn('fs', modeled_modules)\n        self.assertIn('util', modeled_modules)\n        self.assertIn('path', modeled_modules)\n\n    def test_modeled_modules_callable(self):\n        \"\"\"Test that modeled_modules entries are callable.\"\"\"\n        for name, module_setup in modeled_modules.items():\n            self.assertTrue(callable(module_setup), f\"{name} setup should be callable\")\n\n\nclass TestReadFile(unittest.TestCase):\n    def test_read_file_basic(self):\n        \"\"\"Test basic read_file functionality.\"\"\"\n        G = MockGraph()\n\n        path_result = NodeHandleResult(obj_nodes=[G.add_obj_node(None, \"string\", \"/test/file.js\")])\n        callback_result = NodeHandleResult(obj_nodes=[G.add_obj_node(None, \"function\", None)])\n\n        result = read_file(G, None, None, None, path_result, None, callback_result)\n\n        self.assertIsInstance(result, NodeHandleResult)\n\n    def test_read_file_with_options(self):\n        \"\"\"Test read_file with options parameter.\"\"\"\n        G = MockGraph()\n\n        path_result = NodeHandleResult(obj_nodes=[G.add_obj_node(None, \"string\", \"/test/file.js\")])\n        options_result = NodeHandleResult(obj_nodes=[G.add_obj_node(None, \"string\", \"utf8\")])\n        callback_result = NodeHandleResult(obj_nodes=[G.add_obj_node(None, \"function\", None)])\n\n        result = read_file(G, None, None, None, path_result, options_result, callback_result)\n\n        self.assertIsInstance(result, NodeHandleResult)\n\n\nif __name__ == \"__main__\":\n    unittest.main()\n"
}
