00255| def to_og_array(G: Graph, elements, edge_data, ast_node=None):
00256|     added_array = G.add_obj_node(ast_node=ast_node, js_type="array")
00257|     for i, elem in enumerate(elements):
00258|         name_node = G.add_prop_name_node(name=str(i), parent_obj=added_array)
00259|         for j, obj in enumerate(elem):
00260|             G.add_edge(name_node, obj, {"type:TYPE": "NAME_TO_OBJ", **edge_data[i][j]})
00261|     G.add_obj_as_prop(
00262|         prop_name="length",
00263|         ast_node=ast_node,
00264|         js_type="number",
00265|         value=len(elements),
00266|         parent_obj=added_array,
00267|     )
00268|     return added_array
