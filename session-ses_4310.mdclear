00021| from .expressions import (
00022|     Add,
00023|     Choice,
00024|     Concat,
00025|     ConstNumber,
00026|     ConstString,
00027|     Expression,
00028|     Sub,
00029|     Symbol,
00030|     UnknownOp,
00031| )
00032| 
00033| logger = logging.getLogger(__name__)
00034| 
00035| 
00036| def _node_type(G, node_id):
00037|     return G.get_node_attr(node_id).get("type")
00038| 
00039| 
00040| def _node_value(G, node_id):
00041|     return G.get_node_attr(node_id).get("code")
00042| 
00043| 
00044| def _node_taint(G, node_id):
00045|     return bool(G.get_node_attr(node_id).get("tainted"))
00046| 
00047| 
00048| def build_expressions(
00049|     G, target_obj_ids, contains: bool = True
00050| ) -> Dict[str, Expression]:
00051|     """
00052|     Build expression DAGs for each target object by following CONTRIBUTES_TO edges.
00053| 
00054|     This function constructs an intermediate representation (IR) of how values flow
00055|     through operations in the graph. It follows CONTRIBUTES_TO edges backward from
00056|     target objects (typically sinks) to build a directed acyclic graph (DAG) of
00057|     expressions.
00058| 
00059|     The expression DAG represents:
00060|     - Leaf nodes: Constants (strings, numbers) or symbols (variables)
00061|     - Internal nodes: Operations (concatenation, addition, etc.)
00062|     - Choice nodes: Multiple possible expressions (from different execution paths)
00063| 
00064|     This IR is then encoded to Z3 constraints for solving. The DAG structure allows for efficient constraint generation and enables optimizations like common
00065|     subexpression elimination.
00066| 
00067|     Args:
00068|         G: Graph instance containing the analysis results.
00069|         target_obj_ids: Iterable of target object node IDs to build expressions for.
00070|             Typically these are sink objects that reach vulnerable functions.
00071|         contains: Whether sink values should be modeled as "contains" (substring match)
00072|             instead of equality. When True, allows finding inputs that produce the
00073|             desired payload as a substring. Defaults to True.
00074| 
00075|     Returns:
00076|         dict: Mapping from target object ID to Expression DAG. Each Expression
00077|             represents how the value of that object is computed from source inputs.
00078| 
00079|     Example:
00080|         >>> # Build expressions for sink objects
00081|         >>> expressions = build_expressions(G, [sink_obj1, sink_obj2])
00082|         >>> # Encode to Z3 and solve
00083|         >>> for obj_id, expr in expressions.items():
00084|         ...     solver = z3.Solver()
00085|         ...     term = encode_to_z3(expr, solver)
00086|         ...     solver.add(z3.Contains(term, z3.StringVal("payload")))
00087|         ...     if solver.check() == z3.sat:
00088|         ...         print("Exploit found:", solver.model())
00089|     """
00090|     memo: Dict[str, Expression] = {}
00091| 
00092|     def build(node_id: str) -> Expression:
00093|         if node_id in memo:
00094|             return memo[node_id]
00095| 
00096|         node_tainted = _node_taint(G, node_id)
00097|         node_type = _node_type(G, node_id)
00098|         node_value = _node_value(G, node_id)
00099| 
00100|         in_edges = G.get_in_edges(node_id, edge_type="CONTRIBUTES_TO")
00101| 
00102|         if not in_edges:
00103|             expr = _leaf_expr(node_id, node_type, node_value, node_tainted)
00104|             memo[node_id] = expr
00105|             return expr
00106| 
00107|         grouped = _group_contributors(in_edges)
00108|         options: List[Expression] = []
00109|         for (op, _group), sources in grouped.items():
00110|             # ensure deterministic ordering by index
00111|             sources = sorted(sources, key=lambda s: s[1])
00112|             child_exprs = [build(src) for src, _idx in sources]
00113|             expr = _op_to_expr(op, child_exprs, node_tainted)
00114|             options.append(expr)
00115| 
00116|         if not options:
00117|             expr = _leaf_expr(node_id, node_type, node_value, node_tainted)
00118|         elif len(options) == 1:
00119|             expr = options[0]
00120|         else:
00121|             expr = Choice(options=options, tainted=node_tainted)
00122| 
00123|         memo[node_id] = expr
00124|         return expr
00125| 
00126|     return {t: build(str(t)) for t in target_obj_ids}
00127| 
00128| 
00129| def _leaf_expr(node_id, node_type, node_value, tainted):
00130|     if node_type == "string" and node_value not in (None, wildcard):
00131|         return ConstString(value=str(node_value), tainted=tainted)
00132|     if node_type == "number" and node_value not in (None, wildcard):
00133|         try:
00134|             return ConstNumber(value=float(node_value), tainted=tainted)
00135|         except (TypeError, ValueError):
00136|             pass
00137|     return Symbol(node_id=str(node_id), type_hint=node_type, tainted=tainted)
00138| 
00139| 
00140| def _group_contributors(in_edges) -> Dict[Tuple[str, str], List[Tuple[str, int]]]:
00141|     """
00142|     Groups contributors by (op, group-id) and keeps operand index.
00143|     Edge format: (src, dst, data) where data may hold 'opt' = (op, rnd, idx).
00144|     """
00145|     grouped: Dict[Tuple[str, str], List[Tuple[str, int]]] = {}
00146|     for src, _dst, data in in_edges:
00147|         opt = data.get("opt")
00148|         if not opt:
00149|             key = ("unknown", "none")
00150|             idx = len(grouped.get(key, []))
00151|         elif len(opt) < 3:
00152|             op = opt[0] if len(opt) >= 1 and opt[0] else "unknown"
00153|             group = opt[1] if len(opt) >= 2 and opt[1] else "none"
00154|             key = (op, group)
00155|             idx = len(grouped.get(key, []))
00156|         else:
00157|             op, group, idx = opt[0], opt[1], opt[2]
00158|             key = (op, group)
00159|         grouped.setdefault(key, []).append((src, int(idx)))
00160|     return grouped
00161| 
00162| 
00163| def _group_contributors_with_data(
00164|     in_edges,
00165| ) -> Dict[Tuple[str, str], List[Tuple[str, int, Dict]]]:
00166|     """
00167|     Like _group_contributors but preserves edge data for guard extraction.
00168|     """
00169|     grouped: Dict[Tuple[str, str], List[Tuple[str, int, Dict]]] = {}
00170|     for src, _dst, data in in_edges:
00171|         opt = data.get("opt")
00172|         if not opt:
00173|             key = ("unknown", "none")
00174|             idx = len(grouped.get(key, []))
00175|         elif len(opt) < 3:
00176|             op = opt[0] if len(opt) >= 1 and opt[0] else "unknown"
00177|             group = opt[1] if len(opt) >= 2 and opt[1] else "none"
00178|             key = (op, group)
00179|             idx = len(grouped.get(key, []))
00180|         else:
00181|             op, group, idx = opt[0], opt[1], opt[2]
00182|             key = (op, group)
00183|         grouped.setdefault(key, []).append((src, int(idx), data))
00184|     return grouped
00185| 
00186| 
00187| def _op_to_expr(op: str, args: List[Expression], tainted: bool) -> Expression:
00188|     op = op or "unknown"
00189|     if op == "string_concat":
00190|         return Concat(parts=args, tainted=tainted)
00191|     if op == "numeric_add":
00192|         return Add(terms=args, tainted=tainted)
00193|     if op == "unknown_add":
00194|         # Could be string or numeric; represent as choice
00195|         return Choice(
00196|             options=[
00197|                 Concat(parts=args, tainted=tainted),
00198|                 Add(terms=args, tainted=tainted),
00199|             ],
00200|             tainted=tainted,
00201|         )
00202|     if op == "sub":
00203|         if len(args) == 2:
00204|             return Sub(left=args[0], right=args[1], tainted=tainted)
00205|         if args:
00206|             # fall back to left-associative subtraction
00207|             head, *rest = args
00208|             return Sub(
00209|                 left=head, right=Add(terms=rest, tainted=tainted), tainted=tainted
00210|             )
00211|     if op == "array_join":
00212|         return Concat(parts=args, tainted=tainted)
00213|     return UnknownOp(op=op, args=args, tainted=tainted)
00214| 
00215| 
00216| def _edge_to_condition(data: Dict) -> Condition:
00217|     """
00218|     Extracts a guard condition from edge data if present.
00219|     """
00220|     if not data:
00221|         return TrueCondition()
00222|     for key in ("guard", "condition", "cond", "predicate"):
00223|         if key in data and data[key]:
00224|             raw = data[key]
00225|             if isinstance(raw, Condition):
00226|                 return raw
00227|             if isinstance(raw, str):
00228|                 return NamedCondition(raw)
00229|             if isinstance(raw, tuple) and len(raw) == 3:
00230|                 op, left, right = raw
00231| 
00232|                 def _to_expr(val):
00233|                     if isinstance(val, str):
00234|                         return Symbol(node_id=str(val))
00235|                     return val
00236| 
00237|                 return Predicate(op=op, left=_to_expr(left), right=_to_expr(right))
00238|     return TrueCondition()
00239| 
00240| 
00241| def _combine_conditions(conds: Iterable[Condition]) -> Condition:
00242|     parts = []
00243|     for c in conds:
00244|         if isinstance(c, TrueCondition):
00245|             continue
00246|         if isinstance(c, AndCondition):
00247|             parts.extend(c.parts)
00248|         else:
00249|             parts.append(c)
00250|     if not parts:
00251|         return TrueCondition()
00252|     if len(parts) == 1:
00253|         return parts[0]
00254|     return AndCondition(parts=parts)
00255| 
00256| 
00257| def build_path_constraints(
00258|     G,
00259|     target_obj_ids: Iterable[str],
00260|     *,
00261|     path_nodes: Optional[Iterable[str]] = None,
00262|     contains: bool = True,
00263|     sink_value: Optional[Union[str, int, float]] = None,
00264| ) -> Dict[str, List[PathConstraint]]:
00265|     """
00266|     Build path-sensitive constraints for each target object.
00267| 
00268|     This performs a forward-style expansion over CONTRIBUTES_TO edges while
00269|     preserving guards per edge. Each returned PathConstraint is a unique
00270|     combination of operand paths and associated path conditions.
00271|     """
00272|     allowed_nodes = set(map(str, path_nodes)) if path_nodes else None
00273|     memo: Dict[str, List[PathConstraint]] = {}
00274| 
00275|     def build(node_id: str) -> List[PathConstraint]:
00276|         if node_id in memo:
00277|             return memo[node_id]
00278| 
00279|         node_tainted = _node_taint(G, node_id)
00280|         node_type = _node_type(G, node_id)
00281|         node_value = _node_value(G, node_id)
00282| 
00283|         in_edges = G.get_in_edges(node_id, edge_type="CONTRIBUTES_TO")
00284|         if allowed_nodes is not None:
00285|             in_edges = [
00286|                 e for e in in_edges if str(e[0]) in allowed_nodes and str(e[1]) in allowed_nodes
00287|             ]
00288| 
00289|         if not in_edges:
00290|             expr = _leaf_expr(node_id, node_type, node_value, node_tainted)
00291|             memo[node_id] = [PathConstraint(expr=expr, condition=TrueCondition())]
00292|             return memo[node_id]
00293| 
00294|         grouped = _group_contributors_with_data(in_edges)
00295|         results: List[PathConstraint] = []
00296| 
00297|         for (op, _group), sources in grouped.items():
00298|             # ensure deterministic ordering by index
00299|             sources = sorted(sources, key=lambda s: s[1])
00300|             child_lists: List[List[PathConstraint]] = []
00301|             edge_guards: List[Condition] = []
00302|             for src, idx, data in sources:
00303|                 child_lists.append(build(src))
00304|                 edge_guards.append(_edge_to_condition(data))
00305| 
00306|             # Cartesian product over child path constraints to preserve path sensitivity
00307|             for combo in itertools.product(*child_lists):
00308|                 child_exprs = [pc.expr for pc in combo]
00309|                 child_conditions = [pc.condition for pc in combo] + edge_guards
00310|                 expr = _op_to_expr(op, child_exprs, node_tainted)
00311|                 cond = _combine_conditions(child_conditions)
00312|                 results.append(PathConstraint(expr=expr, condition=cond))
00313| 
00314|         if not results:
00315|             expr = _leaf_expr(node_id, node_type, node_value, node_tainted)
00316|             results = [PathConstraint(expr=expr, condition=TrueCondition())]
00317| 
00318|         # If this is a sink and a desired value is provided, attach a contains/equality predicate
00319|         if sink_value is not None and node_type == "string":
00320|             extra_pred = Predicate(
00321|                 op="contains" if contains else "eq",
00322|                 left=results[0].expr,
00323|                 right=str(sink_value),
00324|             )
00325|             results = [
00326|                 PathConstraint(expr=pc.expr, condition=_combine_conditions([pc.condition, extra_pred]))
00327|                 for pc in results
00328|             ]
00329| 
00330|         memo[node_id] = results
00331|         return results
00332| 
00333|     return {t: build(str(t)) for t in target_obj_ids}
00334| 

