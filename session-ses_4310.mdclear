00157| 
00158| def do_vul_checking(G, rule_list, pathes):
00159|     """
00160|     Check paths against a list of trace rules to identify vulnerabilities.
00161| 
00162|     This function applies a list of trace rules to candidate paths. A path
00163|     is considered vulnerable if it satisfies ALL rules in the rule_list.
00164|     Each rule is a tuple of (rule_function_name, rule_arguments).
00165| 
00166|     The function works by:
00167|     1. Creating TraceRule objects for each rule in the rule_list
00168|     2. For each candidate path, checking all rules in sequence
00169|     3. If any rule fails, the path is rejected
00170|     4. Only paths that pass all rules are returned
00171| 
00172|     Common rule types:
00173|     - 'has_user_input': Checks if path contains tainted user input
00174|     - 'not_exist_func': Checks that specified functions don't appear in path
00175|     - 'exist_func': Checks that specified functions appear in path
00176|     - 'end_with_func': Checks that path ends at a specific function call
00177|     - 'start_with_func': Checks that path starts at a specific function
00178|     - 'start_within_file': Checks that path starts in a specific file
00179|     - 'not_start_within_file': Checks that path doesn't start in specific files
00180| 
00181|     Args:
00182|         G (Graph): The graph object containing the analysis results
00183|         rule_list (list): List of rule tuples. Each tuple contains:
00184|             - rule_function_name (str): Name of the trace rule function.
00185|               Must match a method name in TraceRule class.
00186|             - rule_arguments: Arguments for the rule function. Can be:
00187|               - None: No arguments needed
00188|               - list: List of function names, file names, or variable names
00189|               - Other types as required by specific rules
00190|         pathes (list): List of candidate paths to check. Each path is a
00191|             list of node IDs representing an execution path through the graph.
00192| 
00193|     Returns:
00194|         list: List of paths that satisfy all rules in rule_list. Each path
00195|             is a list of node IDs. Empty list if no paths satisfy all rules.
00196| 
00197|     Example:
00198|         >>> # Check for OS command injection: user input reaching exec without sanitization
00199|         >>> rule_list = [
00200|         ...     ('has_user_input', None),  # Path must contain user input
00201|         ...     ('not_exist_func', ['parseInt']),  # No parseInt sanitization
00202|         ...     ('end_with_func', ['sink_hqbpillvul_exec'])  # Ends at exec()
00203|         ... ]
00204|         >>> vulnerable = do_vul_checking(G, rule_list, candidate_paths)
00205|         >>> # Check for XSS: user input reaching HTTP write without sanitization
00206|         >>> xss_rules = [
00207|         ...     ('has_user_input', None),
00208|         ...     ('not_exist_func', ['parseInt']),
00209|         ...     ('end_with_func', ['sink_hqbpillvul_http_write'])
00210|         ... ]
00211|         >>> xss_paths = do_vul_checking(G, xss_rules, paths)
00212|     """
00213|     trace_rules = []
00214|     for rule in rule_list:
00215|         trace_rules.append(TraceRule(rule[0], rule[1], G))
00216| 
00217|     success_pathes = []
00218|     flag = True
00219|     for path in pathes:
00220|         flag = True
00221|         for trace_rule in trace_rules:
00222|             if not trace_rule.check(path):
00223|                 flag = False
00224|                 break
00225|         if flag:
00226|             success_pathes.append(path)
00227|     return success_pathes
00228| 
00229| 
00230| def vul_checking(G, pathes, vul_type):
00231|     """
00232|     Filter paths to identify those that satisfy vulnerability detection rules.
00233| 
00234|     This function applies vulnerability-specific trace rules to candidate paths
00235|     and returns only those paths that match the vulnerability pattern. Different
00236|     vulnerability types have different rule sets that check for:
00237|     - Presence of user input (source)
00238|     - Absence of sanitization functions
00239|     - Presence of vulnerable sink functions
00240|     - Path characteristics specific to each vulnerability type
00241| 
00242|     The function uses a rule-based approach where each vulnerability type has
00243|     one or more rule lists. A path is considered vulnerable if it satisfies
00244|     ALL rules in at least one rule list. This allows for multiple patterns
00245|     to be detected for the same vulnerability type.
00246| 
00247|     Rule evaluation:
00248|     - Rules are applied in order within each rule list
00249|     - All rules in a list must pass for the path to be vulnerable
00250|     - If any rule fails, the next rule list is tried
00251|     - A path is added to results if it satisfies any complete rule list
00252| 
00253|     Args:
00254|         G (Graph): The graph object containing the analysis results
00255|         pathes (list): List of candidate paths (sequences of node IDs) to check.
00256|             Each path represents a potential data flow from source to sink.
00257|         vul_type (str): Type of vulnerability to check. Must be one of:
00258|             - 'xss': Cross-site scripting - checks for unsanitized user input
00259|               reaching HTTP response writing functions
00260|             - 'os_command': OS command injection - checks for user input reaching
00261|               command execution functions (exec, spawn, etc.)
00262|             - 'code_exec': Code execution vulnerabilities - checks for user input
00263|               reaching eval(), Function(), or command execution
00264|             - 'proto_pollution': Prototype pollution - checks for tainted property
00265|               names being assigned to prototype chains
00266|             - 'path_traversal': Path traversal - checks for URL parameters reaching
00267|               file system operations without sanitization
00268|             - 'nosql': NoSQL injection - checks for user input reaching MongoDB
00269|               query functions without sanitization
00270| 
00271|     Returns:
00272|         list: List of paths that satisfy the vulnerability detection rules.
00273|             Each path is a list of node IDs representing the vulnerable execution
00274|             path from source to sink. Empty list if no vulnerable paths found.
00275| 
00276|     Example:
00277|         >>> from jsflow.vul_checking import vul_checking
00278|         >>> # Check for XSS vulnerabilities
00279|         >>> vulnerable_paths = vul_checking(G, candidate_paths, 'xss')
00280|         >>> print(f"Found {len(vulnerable_paths)} XSS vulnerabilities")
00281|         >>> # Check for OS command injection
00282|         >>> cmd_paths = vul_checking(G, paths, 'os_command')
00283|     """
00284|     # Vulnerability-specific sanitizer heuristics.
00285|     #
00286|     # Note: This project is intentionally lightweight/heuristic in places.
00287|     # These lists exist to keep regression tests stable while we improve
00288|     # precision of the underlying analysis.
00289|     xss_sanitizers = signature_lists["sanitation"] + ["escapeHtml"]
00290|     os_command_sanitizers = signature_lists["sanitation"] + ["has"]
00291|     path_traversal_sanitizers = signature_lists["sanitation"] + [
00292|         "normalize",
00293|         "join",
00294|         "startsWith",
00295|     ]
00296| 
00297|     xss_rule_lists = [
00298|         [
00299|             ("has_user_input", None),
00300|             ("not_start_with_func", ["sink_hqbpillvul_http_write"]),
00301|             ("not_exist_func", xss_sanitizers),
00302|             ("end_with_func", ["sink_hqbpillvul_http_write"]),
00303|         ],
00304|         [
00305|             ("has_user_input", None),
00306|             ("not_start_with_func", ["sink_hqbpillvul_http_setHeader"]),
00307|             ("not_exist_func", xss_sanitizers),
00308|             ("end_with_func", ["sink_hqbpillvul_http_setHeader"]),
00309|         ],
00310|         # Express-style response sinks (often appear as dummy functions).
00311|         [
00312|             ("has_user_input", None),
00313|             ("not_start_with_func", ["res.send"]),
00314|             ("not_exist_func", xss_sanitizers),
00315|             ("end_with_func", ["res.send"]),
00316|         ],
00317|     ]
00318|     os_command_rule_lists = [
00319|         [
00320|             ("has_user_input", None),
00321|             ("not_start_within_file", ["child_process.js"]),
00322|             ("not_exist_func", os_command_sanitizers),
00323|             (
00324|                 "exist_func",
00325|                 signature_lists["os_command"]
00326|                 + [
00327|                     "child_process.exec",
00328|                     "child_process.execFile",
00329|                     "child_process.execSync",
00330|                     "child_process.spawn",
00331|                     "child_process.spawnSync",
00332|                 ],
00333|             ),
00334|         ]
00335|     ]
00336| 
00337|     code_exec_lists = [
00338|         [
00339|             ("has_user_input", None),
00340|             ("not_start_within_file", ["eval.js"]),
00341|             ("not_exist_func", ["parseInt"]),
00342|         ],
00343|         [
00344|             ("has_user_input", None),
00345|             ("end_with_func", ["Function"]),
00346|             ("not_exist_func", ["parseInt"]),
00347|         ],
00348|         [
00349|             ("has_user_input", None),
00350|             ("end_with_func", ["eval"]),
00351|             ("not_exist_func", ["parseInt"]),
00352|         ],
00353|         # include os command here
00354|         [
00355|             ("has_user_input", None),
00356|             ("not_start_within_file", ["child_process.js"]),
00357|             ("not_exist_func", ["parseInt"]),
00358|         ],
00359|     ]
00360|     proto_pollution = [
00361|         [("has_user_input", None), ("not_exist_func", signature_lists["sanitation"])]
00362|     ]
00363|     path_traversal = [
00364|         # Direct fs reads in application code.
00365|         [
00366|             ("has_user_input", None),
00367|             ("not_exist_func", path_traversal_sanitizers),
00368|             ("end_with_func", ["fs.readFile", "fs.readFileSync"]),
00369|         ],
00370|         [
00371|             ("has_user_input", None),
00372|             # Avoid flagging flows that only exist inside the built-in `fs.js` stub;
00373|             # prefer detecting at the application callsite (rule list above).
00374|             ("not_start_within_file", ["fs.js"]),
00375|             ("not_exist_func", path_traversal_sanitizers),
00376|             ("end_with_func", signature_lists["path_traversal"]),
00377|             ("exist_func", ["sink_hqbpillvul_fs_read"]),
00378|             # ('exist_func', ['__opgCombine'])
00379|         ],
00380|         [
00381|             ("has_user_input", None),
00382|             ("not_exist_func", path_traversal_sanitizers),
00383|             ("end_with_func", ["sink_hqbpillvul_http_sendFile"]),
00384|         ],
00385|     ]
00386|     nosql_rule_lists = [
00387|         [
00388|             ("has_user_input", None),
00389|             ("not_start_within_file", ["mongodb.js", "monk.js"]),
00390|             ("not_exist_func", signature_lists["sanitation"]),
00391|             ("exist_func", signature_lists["nosql"]),
00392|         ]
00393|     ]
00394| 
00395|     vul_type_map = {
00396|         "xss": xss_rule_lists,
00397|         "os_command": os_command_rule_lists,
00398|         "code_exec": code_exec_lists,
00399|         "proto_pollution": proto_pollution,
00400|         "path_traversal": path_traversal,
00401|         "nosql": nosql_rule_lists,
00402|     }
00403| 
00404|     rule_lists = vul_type_map[vul_type]
00405|     success_paths = []
00406|     print("vul_checking", vul_type)
00407|     """
00408|     print(pathes)
00409|     for path in pathes:
00410|         for node in path:
00411|             print(G.get_node_attr(node))
00412|     """
00413|     for rule_list in rule_lists:
00414|         success_paths += do_vul_checking(G, rule_list, pathes)
00415|     # success_paths = list(map(lambda path: G.extend_path_by_cf(path), success_paths))
00416|     print("success: ", success_paths)
00417|     return success_paths
00418| 
00419| 
00420| def check_pp(G):
00421|     """
00422|     Detect prototype pollution patterns.
00423| 
00424|     This checker is intentionally heuristic: prototype pollution often happens
00425|     through "deep set"/"deep merge" helpers instead of explicit writes to
00426|     `Object.prototype`.
00427| 
00428|     We look for:
00429|     - Direct writes to dangerous keys (`__proto__`, `prototype`, `constructor`)
00430|       where key/value is influenced by user input.
00431|     - Writes to built-in prototypes (Object/String/Array/Function/...) with
00432|       user-controlled property names.
00433|     - Calls to merge/set-like helpers where attacker-controlled objects/paths
00434|       can introduce dangerous keys.
00435|     """
00436|     print("Checking proto_pollution...")
00437| 
00438|     DANGEROUS_KEYS = {"__proto__", "prototype", "constructor"}
00439| 
00440|     # Common helper names that can lead to prototype pollution when fed an
00441|     # attacker-controlled object or property path.
00442|     #
00443|     # Note: We intentionally include both bare names and common qualified names
00444|     # (e.g. Object.assign, _.merge) because JSFlow often loses module/receiver
00445|     # identity in graphs.
00446|     MERGE_LIKE_FUNCS = {
00447|         "merge",
00448|         "mergewith",
00449|         "mergeWith",
00450|         "deepmerge",
00451|         "deepMerge",
00452|         "extend",
00453|         "extendwith",
00454|         "extendWith",
00455|         "assign",
00456|         "assignin",
00457|         "assignIn",
00458|         "defaultsdeep",
00459|         "defaultsDeep",
00460|         "defaults",
00461|         "Object.assign",
00462|         "object.assign",
00463|         "_.merge",
00464|         "_.mergeWith",
00465|         "_.defaultsDeep",
00466|         "_.assign",
00467|         "lodash.merge",
00468|         "lodash.mergeWith",
00469|         "lodash.defaultsDeep",
00470|         "$.extend",
00471|         "jquery.extend",
00472|         "jQuery.extend",
00473|         "jQuery.fn.extend",
00474|     }
00475|     SET_LIKE_FUNCS = {
00476|         "set",
00477|         "setwith",
00478|         "setWith",
00479|         "merge.set",
00480|         "baseSet",
00481|         "baseset",
00482|         "put",
00483|         "putil.set",
00484|         "dot-prop.set",
00485|         "dotprop.set",
00486|         "object-path.set",
00487|         "objectpath.set",
00488|         "lodash.set",
00489|         "_.set",
00490|         # Common vulnerable helpers (e.g. arr-flatten-unflatten).
00491|         "unflatten",
00492|         "arr-unflatten",
00493|         "arr-flatten-unflatten",
00494|     }
00495| 
00496|     MERGE_LIKE_FUNCS_LOWER = {m.lower() for m in MERGE_LIKE_FUNCS}
00497|     SET_LIKE_FUNCS_LOWER = {s.lower() for s in SET_LIKE_FUNCS}
00498| 
00499|     def _get_children(node_id, edge_type=None, child_type=None, child_label=None, edge_scope=None):
00500|         children, scopes = [], []
00501|         edges = G.get_out_edges(node_id, edge_type=edge_type)
00502|         for edge in edges:
00503|             aim = edge[1]
00504|             aim_node_attr = G.get_node_attr(aim)
00505|             aim_edge_scope = edge[-1].get("scope")
00506|             if child_type is not None and aim_node_attr.get("type") != child_type:
00507|                 continue
00508|             if child_label is not None and aim_node_attr.get("labels:label") != child_label:
00509|                 continue
00510|             if edge_scope is not None and aim_edge_scope != edge_scope:
00511|                 continue
00512|             children.append(aim)
00513|             scopes.append(aim_edge_scope)
00514|         return children, scopes
00515| 
00516|     def _is_tainted_obj(obj_node) -> bool:
00517|         return bool(G.get_node_attr(obj_node).get("tainted"))
00518| 
00519|     def _is_wildcard_or_tainted(obj_node) -> bool:
00520|         return _is_tainted_obj(obj_node) or is_wildcard_obj(G, obj_node)
00521| 
00522|     def _is_wildcard_or_tainted_string(obj_node) -> bool:
00523|         """
00524|         Property keys are usually strings; treat wildcard strings as attacker-controlled.
00525|         Avoid counting wildcard numbers (array indices) as controlled keys.
00526|         """
00527|         attrs = G.get_node_attr(obj_node)
00528|         if _is_tainted_obj(obj_node):
00529|             return True
00530|         if not is_wildcard_obj(G, obj_node):
00531|             return False
00532|         t = attrs.get("type")
00533|         return t == "string" or t == wildcard
00534| 
00535|     def _obj_to_string(obj_node):
00536|         """
00537|         Best-effort extraction of a string value for an Object node.
00538|         """
00539|         attrs = G.get_node_attr(obj_node)
00540|         v = attrs.get("value")
00541|         if v is None:
00542|             v = attrs.get("code")
00543|         if v is None:
00544|             v = attrs.get("name")
00545|         if v is None:
00546|             return None
00547|         if v == wildcard:
00548|             return None
00549|         s = str(v).strip()
00550|         # strip quotes if present
00551|         if len(s) >= 2 and ((s[0] == s[-1] == "'") or (s[0] == s[-1] == '"')):
00552|             s = s[1:-1]
00553|         return s
00554| 
00555|     def _expr_obj_nodes(expr_ast, scope):
00556|         obj_nodes, _ = _get_children(expr_ast, edge_type="REFERS_TO", child_label="Object", edge_scope=scope)
00557|         return obj_nodes
00558| 
00559|     def _expr_is_tainted(expr_ast, scope) -> bool:
00560|         return any(_is_tainted_obj(o) for o in _expr_obj_nodes(expr_ast, scope))
00561| 
00562|     def _expr_is_tainted_or_wildcard_string(expr_ast, scope) -> bool:
00563|         return any(_is_wildcard_or_tainted_string(o) for o in _expr_obj_nodes(expr_ast, scope))
00564| 
00565|     def _string_has_dangerous_key_segment(s: str) -> bool:
00566|         """
00567|         Detect dangerous keys not only as a full key, but inside dotted / bracketed paths.
00568|         Examples:
00569|           "__proto__"
00570|           "__proto__.polluted"
00571|           "constructor.prototype.polluted"
00572|           "a['__proto__'].b"
00573|         """
00574|         if not s:
00575|             return False
00576|         lower = s.lower()
00577|         if "__proto__" in lower:
00578|             return True
00579|         if "constructor" in lower and "prototype" in lower:
00580|             return True
00581|         # Tokenize on non-identifier chars to catch bracket/dot variants.
00582|         for tok in re.split(r"[^a-zA-Z0-9_$]+", lower):
00583|             if tok in DANGEROUS_KEYS:
00584|                 return True
00585|         return False
00586| 
00587|     def _expr_has_dangerous_literal(expr_ast, scope) -> bool:
00588|         """
00589|         Best-effort: if we can resolve a literal string value for the expression,
00590|         check whether it is a dangerous key.
00591|         """
00592|         for o in _expr_obj_nodes(expr_ast, scope):
00593|             s = _obj_to_string(o)
00594|             if s is None:
00595|                 continue
00596|             if s in DANGEROUS_KEYS:
00597|                 return True
00598|             if _string_has_dangerous_key_segment(s):
00599|                 return True
00600|         # Fallback to AST code if available (e.g. '"__proto__"')
00601|         code = G.get_node_attr(expr_ast).get("code")
00602|         if isinstance(code, str):
00603|             c = code.strip().strip("'\"")
00604|             if c in DANGEROUS_KEYS or _string_has_dangerous_key_segment(c):
00605|                 return True
00606|         return False
00607| 
00608|     def _call_names(call_ast):
00609|         """
00610|         Return a small set of possible call names for matching:
00611|         - receiver.method
00612|         - method
00613|         - fallback name
00614|         """
00615|         node_attr = G.get_node_attr(call_ast)
00616|         names = []
00617|         if node_attr.get("type") == "AST_METHOD_CALL":
00618|             children = G.get_ordered_ast_child_nodes(call_ast)
00619|             if len(children) >= 2:
00620|                 receiver = G.get_name_from_child(children[0], order=1)
00621|                 method = G.get_name_from_child(children[1], order=1)
00622|                 if receiver and method:
00623|                     names.append(f"{receiver}.{method}")
00624|                 if method:
00625|                     names.append(method)
00626|         fallback = G.get_name_from_child(call_ast, order=1)
00627|         if fallback:
00628|             names.append(fallback)
00629|         # preserve order but remove duplicates
00630|         out = []
00631|         for n in names:
00632|             if n not in out:
00633|                 out.append(n)
00634|         return out
00635| 
00636|     def _name_looks_merge_like(name: str) -> bool:
00637|         n = name.lower()
00638|         if n in MERGE_LIKE_FUNCS_LOWER:
00639|             return True
00640|         # Heuristic fallbacks for library-internal helpers (e.g. lodash baseMerge).
00641|         return any(tok in n for tok in ("merge", "extend", "assign", "defaultsdeep"))
00642| 
00643|     def _name_looks_set_like(name: str) -> bool:
00644|         n = name.lower()
00645|         if n in SET_LIKE_FUNCS_LOWER:
00646|             return True
00647|         # Avoid matching unrelated words like "asset" by requiring a boundary-ish context.
00648|         if "unflatten" in n:
00649|             return True
00650|         if n.endswith("set") or n.endswith(".set") or n.endswith("_set"):
00651|             return True
00652|         return any(tok in n for tok in ("object-path", "dot-prop", "putil", "setobject", "set-object"))
00653| 
00654|     def _receiver_looks_pollutable(prop_expr_ast, scope) -> bool:
00655|         """
00656|         Heuristic: identify writes that target built-in prototypes / their properties.
00657|         """
00658|         # Old approach: REFERS_TO Name nodes intersecting known pollutable names.
00659|         name_nodes, _ = _get_children(prop_expr_ast, edge_type="REFERS_TO", child_label="Name", edge_scope=scope)
00660|         if set(name_nodes) & set(getattr(G, "pollutable_name_nodes", set())):
00661|             return True
00662|         # Also consider receiver objects being known pollutable objects.
00663|         try:
00664|             receiver_ast = G.get_ordered_ast_child_nodes(prop_expr_ast)[0]
00665|         except Exception:
00666|             return False
00667|         recv_objs = _expr_obj_nodes(receiver_ast, scope)
00668|         if set(recv_objs) & set(getattr(G, "pollutable_objs", set())):
00669|             return True
00670|         return False
00671| 
00672|     results = set()
00673| 
00674|     # 1) Direct assignment patterns: x[ key ] = value / x.key = value
00675|     for assign in G.get_node_by_attr("type", "AST_ASSIGN"):
00676|         children = G.get_ordered_ast_child_nodes(assign)
00677|         if len(children) < 2:
00678|             continue
00679|         left, right = children[:2]
00680|         if G.get_node_attr(left).get("type") not in ["AST_DIM", "AST_PROP"]:
00681|             continue
00682| 
00683|         # Determine scopes in which the left side is resolved
00684|         _, scopes = _get_children(left, edge_type="REFERS_TO", child_label="Name")
00685|         # Some AST nodes don't carry REFERS_TO edges directly; in that case, fall back
00686|         # to a scope-agnostic check to avoid missing common patterns like `result[key]=...`.
00687|         for scope in (set(scopes) or {None}):
00688|             prop_children = G.get_ordered_ast_child_nodes(left)
00689|             if len(prop_children) < 2:
00690|                 continue
00691|             prop_name_ast = prop_children[1]
00692| 
00693|             # In real-world PP, the dangerous key often comes from iterating attacker-controlled objects.
00694|             # JSFlow frequently models such keys as wildcard strings rather than explicitly tainted.
00695|             key_tainted = _expr_is_tainted_or_wildcard_string(prop_name_ast, scope)
00696|             key_dangerous_literal = _expr_has_dangerous_literal(prop_name_ast, scope)
00697|             value_tainted = _expr_is_tainted(right, scope)
00698| 
00699|             receiver_pollutable = _receiver_looks_pollutable(left, scope)
00700| 
00701|             # Production-oriented: require attacker influence AND a write pattern
00702|             # that can realistically hit prototype gadgets.
00703|             #
00704|             # - If the key is tainted, it may be "__proto__"/"constructor"/"prototype",
00705|             #   so writing to *any* object is potentially polluting (e.g. obj["__proto__"]).
00706|             # - If the key is an explicit dangerous literal, require tainted value
00707|             #   (to avoid flagging intentional hardcoded prototype plumbing).
00708|             # - If the receiver is a known built-in prototype, require tainted key/value.
00709|             if key_tainted:
00710|                 pass  # allow: obj[taintedKey] = ...
00711|             elif key_dangerous_literal:
00712|                 if not value_tainted:
00713|                     continue
00714|             elif receiver_pollutable:
00715|                 if not (key_tainted or value_tainted):
00716|                     continue
00717|             else:
00718|                 continue
00719| 
00720|             # Record finding with a small reason tag for debugging/reporting.
00721|             reason = []
00722|             if key_tainted:
00723|                 reason.append("tainted_key")
00724|             if value_tainted:
00725|                 reason.append("tainted_value")
00726|             if key_dangerous_literal:
00727|                 reason.append("dangerous_key")
00728|             if receiver_pollutable:
00729|                 reason.append("pollutable_receiver")
00730|             G.set_node_attr(assign, ("pp_reason", ",".join(reason)))
00731|             results.add(assign)
00732| 
00733|     # 2) Call patterns: merge/set helpers with attacker-controlled input
00734|     call_nodes = G.get_node_by_attr("type", "AST_CALL") + G.get_node_by_attr("type", "AST_METHOD_CALL")
00735|     for call in call_nodes:
00736|         # Get ordered AST children and locate argument list node (best-effort)
00737|         children = G.get_ordered_ast_child_nodes(call)
00738|         if not children:
00739|             continue
00740| 
00741|         # Determine likely call name(s)
00742|         names = _call_names(call)
00743|         # Also add helper get_func_name (often returns method only)
00744|         fn = get_func_name(G, call)
00745|         if fn and fn not in names:
00746|             names.append(fn)
00747| 
00748|         lowered = {n.lower() for n in names if isinstance(n, str)}
00749|         is_merge_like = any(_name_looks_merge_like(n) for n in lowered)
00750|         is_set_like = any(_name_looks_set_like(n) for n in lowered)
00751|         if not (is_merge_like or is_set_like):
00752|             continue
00753| 
00754|         # Identify scopes for this call site (via any REFERS_TO edge)
00755|         _, scopes = _get_children(call, edge_type="REFERS_TO")
00756|         if not scopes:
00757|             scopes = [None]
00758| 
00759|         for scope in set(scopes):
00760|             # Argument list is usually the last child for calls in this AST format.
00761|             arg_list_ast = children[-1] if children else None
00762|             arg_asts = G.get_ordered_ast_child_nodes(arg_list_ast) if arg_list_ast else []
00763| 
00764|             # Determine whether any argument is wildcard/tainted object-ish.
00765|             arg_obj_nodes = []
00766|             for a in arg_asts:
00767|                 arg_obj_nodes.extend(_expr_obj_nodes(a, scope))
00768| 
00769|             any_tainted_arg_obj = any(_is_wildcard_or_tainted(o) for o in arg_obj_nodes)
00770| 
00771|             # Additionally, check for dangerous literal keys in string/path arguments.
00772|             any_dangerous_key_arg = any(_expr_has_dangerous_literal(a, scope) for a in arg_asts)
00773|             any_tainted_key_arg = any(_expr_is_tainted_or_wildcard_string(a, scope) for a in arg_asts)
00774| 
00775|             # Merge-like: flag when attacker-controlled object is merged/extended/assigned.
00776|             if is_merge_like and any_tainted_arg_obj:
00777|                 reason = ["merge_like", "tainted_arg"]
00778|                 if any_dangerous_key_arg:
00779|                     reason.append("dangerous_key_arg")
00780|                 if any_tainted_key_arg:
00781|                     reason.append("tainted_key_arg")
00782|                 G.set_node_attr(call, ("pp_reason", ",".join(reason)))
00783|                 results.add(call)
00784| 
00785|             # Set-like: flag when key/path is attacker-controlled or explicitly dangerous.
00786|             if is_set_like and (any_tainted_key_arg or any_dangerous_key_arg):
00787|                 reason = ["set_like"]
00788|                 if any_tainted_key_arg:
00789|                     reason.append("tainted_key_arg")
00790|                 if any_dangerous_key_arg:
00791|                     reason.append("dangerous_key_arg")
00792|                 if any_tainted_arg_obj:
00793|                     reason.append("tainted_arg")
00794|                 G.set_node_attr(call, ("pp_reason", ",".join(reason)))
00795|                 results.add(call)
00796| 
00797|     # 3) Structural patterns: for-in loops copying properties to objects
00798|     #
00799|     # Many real-world PP gadgets look like:
00800|     #   for (k in src) dst[k] = src[k]   (or recursive variants)
00801|     # even when JSFlow does not precisely taint `k`.
00802|     #
00803|     # We conservatively flag computed writes inside JS_FOR_IN loops, and
00804|     # specifically detect the common "copy by loop key" pattern.
00805|     def _ast_is_string_literal(ast_id) -> bool:
00806|         code = G.get_node_attr(ast_id).get("code")
00807|         if not isinstance(code, str):
00808|             return False
00809|         c = code.strip()
00810|         return len(c) >= 2 and ((c[0] == c[-1] == "'") or (c[0] == c[-1] == '"'))
00811| 
00812|     for foreach in G.get_node_by_attr("type", "AST_FOREACH"):
00813|         if G.get_node_attr(foreach).get("flags:string[]") != "JS_FOR_IN":
00814|             continue
00815|         try:
00816|             src_obj_ast, _value_ast, key_ast, body_ast = G.get_ordered_ast_child_nodes(foreach)
00817|         except Exception:
00818|             continue
00819| 
00820|         key_name = G.get_name_from_child(key_ast, order=1) or G.get_name_from_child(key_ast)
00821|         body_nodes = set([body_ast])
00822|         try:
00823|             body_nodes.update(G.get_all_child_nodes(body_ast))
00824|         except Exception:
00825|             pass
00826| 
00827|         for assign in (n for n in body_nodes if G.get_node_attr(n).get("type") == "AST_ASSIGN"):
00828|             try:
00829|                 left, right = G.get_ordered_ast_child_nodes(assign)[:2]
00830|             except Exception:
00831|                 continue
00832|             if G.get_node_attr(left).get("type") != "AST_DIM":
00833|                 continue
00834|             try:
00835|                 dim_children = G.get_ordered_ast_child_nodes(left)
00836|                 if len(dim_children) < 2:
00837|                     continue
00838|                 prop_ast = dim_children[1]
00839|             except Exception:
00840|                 continue
00841| 
00842|             prop_code = G.get_node_attr(prop_ast).get("code")
00843|             prop_name = G.get_name_from_child(prop_ast, order=1) or G.get_name_from_child(prop_ast)
00844| 
00845|             # Most common PP copy pattern: dst[key] = ...
00846|             if key_name and prop_name == key_name:
00847|                 G.set_node_attr(assign, ("pp_reason", "for_in_copy_key"))
00848|                 results.add(assign)
00849|                 continue
00850| 
00851|             # Also flag other computed writes inside for-in loops when the key isn't
00852|             # a simple string literal (e.g. curr[prop] where prop is derived from the loop key).
00853|             if not _ast_is_string_literal(prop_ast):
00854|                 # If we can *also* see dangerous path segments in the RHS, bump confidence.
00855|                 rhs_code = G.get_node_attr(right).get("code")
00856|                 if isinstance(rhs_code, str) and _string_has_dangerous_key_segment(rhs_code):
00857|                     G.set_node_attr(assign, ("pp_reason", "for_in_computed_key_rhs_danger"))
00858|                     results.add(assign)
00859|                 else:
00860|                     G.set_node_attr(assign, ("pp_reason", "for_in_computed_key"))
00861|                     results.add(assign)
00862| 
00863|     if results:
00864|         print("found:", results)
00865|     else:
00866|         print("not found")
00867|     return results
00868| 

