00110| def convert_prop_names_to_wildcard(
00111|     G: Graph, obj, exclude_length=False, exclude_proto=True
00112| ):
00113|     wildcard_name_node = G.add_prop_name_node(wildcard, obj)
00114|     for e1 in G.get_out_edges(obj, edge_type="OBJ_TO_PROP"):
00115|         name_node = e1[1]
00116|         if G.get_node_attr(name_node).get("name") == wildcard:
00117|             continue
00118|         if exclude_length and G.get_node_attr(name_node).get("name") == "length":
00119|             continue
00120|         if exclude_proto and G.get_node_attr(name_node).get("name") == "__proto__":
00121|             continue
00122|         for e2 in G.get_out_edges(name_node, edge_type="NAME_TO_OBJ"):
00123|             _, obj, _, data = e2
00124|             G.add_edge(wildcard_name_node, obj, data)
00125|         G.remove_all_edges_between(e1[0], e1[1])
00126| 
00127| 
00128| def copy_objs_for_branch(
00129|     G: Graph, handle_result: NodeHandleResult, branch, ast_node=None, deep=True
00130| ) -> NodeHandleResult:
00131|     """
00132|     Copy objects for branch-aware analysis when entering a conditional branch.
00133| 
00134|     When execution enters a conditional branch (if/switch), objects that are
00135|     assigned in that branch need to be copied to maintain separate state for
00136|     each execution path. This function:
00137|     1. Identifies objects that need copying (assigned in different branches)
00138|     2. Creates copies of those objects
00139|     3. Updates edges to track which objects exist in which branches
00140| 
00141|     The branch tracking uses edge marks:
00142|     - 'A' (Addition): Object is assigned in this branch
00143|     - 'D' (Deletion): Object was assigned in another branch, not valid here
00144| 
00145|     This enables path-sensitive analysis where different branches can have
00146|     different object states.
00147| 
00148|     Args:
00149|         G: Graph instance.
00150|         handle_result: NodeHandleResult containing objects and name nodes to process.
00151|         branch: BranchTag representing the current branch being entered.
00152|         ast_node: Optional AST node for the copy operation (for tracking).
00153|         deep: If True, recursively copy nested object properties. If False,
00154|             only copy top-level object structure. Defaults to True.
00155| 
00156|     Returns:
00157|         NodeHandleResult: Updated result with copied objects. Objects that
00158|             didn't need copying are included as-is.
00159| 
00160|     Example:
00161|         >>> # Entering if branch
00162|         >>> branch = BranchTag(point="If123", branch="0")
00163|         >>> result = copy_objs_for_branch(G, handle_result, branch)
00164|         >>> # result.obj_nodes now contains copies for branch-specific objects
00165|     """
00166|     returned_objs = []
00167|     for obj in handle_result.obj_nodes:
00168|         copied_obj = None
00169|         # Check all name nodes that reference this object
00170|         for e in G.get_in_edges(obj, edge_type="NAME_TO_OBJ"):
00171|             name_node, _, _, data = e
00172|             eb = data.get("branch")
00173|             
00174|             # Object needs copying if:
00175|             # 1. It's referenced by a name node in our result, AND
00176|             # 2. Either it has no branch tag (exists in all paths) OR
00177|             #    it belongs to a different branch of the same branching point
00178|             if name_node in handle_result.name_nodes and (
00179|                 eb is None or (eb.point == branch.point and eb.branch != branch.branch)
00180|             ):
00181|                 if copied_obj is None:  # Copy only once per object
00182|                     copied_obj = G.copy_obj(obj, ast_node, deep=deep)
00183|                     returned_objs.append(copied_obj)
00184|                 
00185|                 # Update edges to track branch state:
00186|                 # - Add edge to copied object with 'A' mark (added in this branch)
00187|                 # - Add edge to original object with 'D' mark (deleted in this branch)
00188|                 edge_attr_a = dict(data)
00189|                 edge_attr_a["branch"] = BranchTag(branch, mark="A")
00190|                 edge_attr_d = dict(data)
00191|                 edge_attr_d["branch"] = BranchTag(branch, mark="D")
00192|                 G.add_edge(name_node, copied_obj, edge_attr_a)
00193|                 G.add_edge(name_node, obj, edge_attr_d)
00194|         
00195|         if copied_obj is None:  # Object didn't need copying - use original
00196|             returned_objs.append(obj)
00197| 
00198|     return NodeHandleResult(
00199|         obj_nodes=returned_objs,
00200|         name=handle_result.name,
00201|         name_node=handle_result.name_nodes,
00202|     )
00203| 
00204| 
00205| def copy_objs_for_parameters(
00206|     G: Graph,
00207|     handle_result: NodeHandleResult,
00208|     ast_node=None,
00209|     number_of_copies=1,
00210|     delete_original=True,
00211| ) -> List[List]:
00212|     # deprecated
00213|     returned_objs = []
00214|     for obj in handle_result.obj_nodes:
00215|         copied_objs = []
00216|         for i in range(number_of_copies):
00217|             copied_objs.append(G.copy_obj(obj, ast_node))
00218|         for e in G.get_in_edges(obj, edge_type="NAME_TO_OBJ"):
00219|             name_node, obj_node, k, data = e
00220|             if name_node in handle_result.name_nodes:
00221|                 if delete_original:
00222|                     G.graph.remove_edge(name_node, obj_node, k)
00223|                 for copied_obj in copied_objs:
00224|                     G.add_edge(name_node, copied_obj, data)
00225|         returned_objs.append(copied_objs)
00226| 
00227|     return returned_objs
00228| 
