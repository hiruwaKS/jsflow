00298| def get_func_name(G: Graph, ast_node, recursive=True):
00299|     """
00300|     Get the called function name (for call expression) or function
00301|     name (for function declaration). If the callee is a method of an
00302|     object, it returns the method name only instead of
00303|     parent.method.
00304|     """
00305|     node_type = G.get_node_attr(ast_node).get("type")
00306|     if node_type in ["AST_FUNC_DECL", "AST_CLOSURE", "AST_STMT_LIST"]:
00307|         name = G.get_name_from_child(ast_node, max_depth=2)
00308|         if not name or name == "{closure}":
00309|             if recursive:
00310|                 return get_func_name(
00311|                     G, G.get_in_edges(ast_node, edge_type="PARENT_OF")[0][0]
00312|                 )
00313|             return None
00314|         return name
00315|     elif node_type in ["AST_METHOD_CALL", "AST_PROP"]:
00316|         return get_func_name(
00317|             G, G.get_ordered_ast_child_nodes(ast_node)[1], recursive=False
00318|         )
00319|     elif node_type in ["AST_CALL", "AST_NEW"]:
00320|         return get_func_name(
00321|             G, G.get_ordered_ast_child_nodes(ast_node)[0], recursive=False
00322|         )
00323|     elif node_type == "AST_ASSIGN":
00324|         children = G.get_ordered_ast_child_nodes(ast_node)
00325|         if len(children) >= 2:
00326|             left, right = children[:2]
00327|             if G.get_node_attr(right).get("type") in ["AST_FUNC_DECL", "AST_CLOSURE"]:
00328|                 return get_func_name(G, left)
00329|     else:
00330|         return G.get_name_from_child(ast_node)
