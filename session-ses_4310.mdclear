  "content": "import unittest\nfrom unittest.mock import MagicMock, Mock\nimport sys\nimport os\n\n# Add parent directory to path\nsys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))\n\nfrom jsflow.vuln.vul_checking import get_path_text, traceback, do_vul_checking, vul_checking\nfrom jsflow.core.trace_rule import TraceRule\n\n\nclass FakeGraphForVulChecking:\n    \"\"\"Extended fake graph for vul_checking tests.\"\"\"\n    def __init__(\n        self,\n        new_trace_rule=True,\n        node_attrs=None,\n        edge_attrs=None,\n        file_paths=None,\n        name_map=None,\n        parent_edges=None,\n        child_nodes=None,\n        logger=None,\n    ):\n        self.new_trace_rule = new_trace_rule\n        self.node_attrs = node_attrs or {}\n        self.edge_attrs = edge_attrs or {}\n        self.file_paths = file_paths or {}\n        self.name_map = name_map or {}\n        self.parent_edges = parent_edges or {}\n        self.child_nodes = child_nodes or {}\n        self.logger = logger or MagicMock()\n\n    def get_node_attr(self, node):\n        return self.node_attrs.get(node, {})\n\n    def get_in_edges(self, node, edge_type=None):\n        return self.parent_edges.get(node, [])\n\n    def get_out_edges(self, node, edge_type=None):\n        # Return empty list by default\n        return []\n\n    def get_name_from_child(self, node, order=None):\n        return self.name_map.get(node)\n\n    def get_node_file_path(self, node):\n        return self.file_paths.get(node)\n\n    def get_edge_attr(self, u, v):\n        return self.edge_attrs.get((u, v), {})\n\n    def get_all_child_nodes(self, node):\n        return self.child_nodes.get(node, [])\n\n    def get_node_by_attr(self, attr_name, attr_value):\n        \"\"\"Get nodes by attribute value.\"\"\"\n        result = []\n        for node, attrs in self.node_attrs.items():\n            if attrs.get(attr_name) == attr_value:\n                result.append(node)\n        return result\n\n    def get_ordered_ast_child_nodes(self, node):\n        \"\"\"Get ordered AST child nodes.\"\"\"\n        return self.child_nodes.get(node, [])\n\n    def find_nearest_upper_CPG_node(self, node):\n        \"\"\"Find nearest upper CPG node.\"\"\"\n        return node\n\n    def _dfs_upper_by_edge_type(self, node, edge_type):\n        \"\"\"DFS upper by edge type.\"\"\"\n        return [[node]]\n\n\nclass TestGetPathText(unittest.TestCase):\n    def test_get_path_text_basic(self):\n        \"\"\"Test get_path_text with basic nodes.\"\"\"\n        G = FakeGraphForVulChecking(\n            node_attrs={\n                1: {\"lineno:int\": \"1\", \"labels:label\": \"Statement\"},\n                2: {\"lineno:int\": \"2\", \"labels:label\": \"Statement\"},\n                3: {\"lineno:int\": \"3\", \"labels:label\": \"Artificial\"},\n            },\n            file_paths={1: \"/tmp/app.js\"},\n        )\n        path = [1, 2]\n        caller = 2\n\n        result = get_path_text(G, path, caller)\n        self.assertIsInstance(result, str)\n        self.assertIn(\"/tmp/app.js\", result)\n\n    def test_get_path_text_skips_artificial_nodes(self):\n        \"\"\"Test that Artificial and Artificial_AST nodes are skipped.\"\"\"\n        G = FakeGraphForVulChecking(\n            node_attrs={\n                1: {\"lineno:int\": \"1\", \"labels:label\": \"Statement\"},\n                2: {\"lineno:int\": \"2\", \"labels:label\": \"Artificial\"},\n                3: {\"lineno:int\": \"3\", \"labels:label\": \"Artificial_AST\"},\n            },\n            file_paths={1: \"/tmp/app.js\"},\n        )\n        path = [1, 2, 3]\n        caller = 3\n\n        result = get_path_text(G, path, caller)\n        # Should not include line numbers for artificial nodes\n        self.assertIsInstance(result, str)\n\n    def test_get_path_text_handles_missing_lineno(self):\n        \"\"\"Test that nodes without lineno are skipped.\"\"\"\n        G = FakeGraphForVulChecking(\n            node_attrs={\n                1: {\"lineno:int\": \"1\", \"labels:label\": \"Statement\"},\n                2: {},  # No lineno\n                3: {\"lineno:int\": \"3\", \"labels:label\": \"Statement\"},\n            },\n            file_paths={1: \"/tmp/app.js\"},\n        )\n        path = [1, 2, 3]\n        caller = 3\n\n        result = get_path_text(G, path, caller)\n        self.assertIsInstance(result, str)\n\n\nclass TestDoVulChecking(unittest.TestCase):\n    def test_do_vul_checking_empty_paths(self):\n        \"\"\"Test do_vul_checking with empty paths.\"\"\"\n        G = FakeGraphForVulChecking(new_trace_rule=True)\n        rule_list = [(\"has_user_input\", None)]\n        paths = []\n\n        result = do_vul_checking(G, rule_list, paths)\n        self.assertEqual(result, [])\n\n    def test_do_vul_checking_single_rule(self):\n        \"\"\"Test do_vul_checking with a single rule.\"\"\"\n        node_attrs = {\n            1: {\"funcid:int\": 100},\n            2: {\"funcid:int\": 200},\n            300: {\"tainted\": True},\n        }\n        edge_attrs = {(1, 2): {0: {\"type:TYPE\": \"OBJ_REACHES\", \"obj\": 300}}}\n        name_map = {100: \"handler\", 200: \"sink_hqbpillvul_http_write\"}\n        G = FakeGraphForVulChecking(\n            new_trace_rule=True,\n            node_attrs=node_attrs,\n            edge_attrs=edge_attrs,\n            name_map=name_map,\n        )\n        path = [1, 2]\n\n        rule_list = [\n            (\"has_user_input\", None),\n            (\"end_with_func\", [\"sink_hqbpillvul_http_write\"]),\n        ]\n        result = do_vul_checking(G, rule_list, [path])\n        self.assertEqual(result, [path])\n\n    def test_do_vul_checking_multiple_rules_all_pass(self):\n        \"\"\"Test do_vul_checking when all rules pass.\"\"\"\n        node_attrs = {\n            1: {\"funcid:int\": 100},\n            2: {\"funcid:int\": 200},\n            300: {\"tainted\": True},\n        }\n        edge_attrs = {(1, 2): {0: {\"type:TYPE\": \"OBJ_REACHES\", \"obj\": 300}}}\n        name_map = {100: \"handler\", 200: \"sink_hqbpillvul_exec\"}\n        G = FakeGraphForVulChecking(\n            new_trace_rule=True,\n            node_attrs=node_attrs,\n            edge_attrs=edge_attrs,\n            name_map=name_map,\n        )\n        path = [1, 2]\n\n        rule_list = [\n            (\"has_user_input\", None),\n            (\"not_exist_func\", [\"parseInt\"]),\n            (\"end_with_func\", [\"sink_hqbpillvul_exec\"]),\n        ]\n        result = do_vul_checking(G, rule_list, [path])\n        self.assertEqual(result, [path])\n\n    def test_do_vul_checking_rule_fails(self):\n        \"\"\"Test do_vul_checking when a rule fails.\"\"\"\n        node_attrs = {\n            1: {\"funcid:int\": 100},\n            2: {\"funcid:int\": 200},\n            300: {\"tainted\": True},\n        }\n        edge_attrs = {(1, 2): {0: {\"type:TYPE\": \"OBJ_REACHES\", \"obj\": 300}}}\n        name_map = {100: \"handler\", 200: \"sink_hqbpillvul_http_write\"}\n        G = FakeGraphForVulChecking(\n            new_trace_rule=True,\n            node_attrs=node_attrs,\n            edge_attrs=edge_attrs,\n            name_map=name_map,\n        )\n        path = [1, 2]\n\n        # Rule that should fail (path doesn't end with the required function)\n        rule_list = [\n            (\"has_user_input\", None),\n            (\"end_with_func\", [\"different_func\"]),\n        ]\n        result = do_vul_checking(G, rule_list, [path])\n        self.assertEqual(result, [])\n\n\nclass TestVulChecking(unittest.TestCase):\n    def test_vul_checking_invalid_type(self):\n        \"\"\"Test vul_checking with invalid vulnerability type.\"\"\"\n        G = FakeGraphForVulChecking(new_trace_rule=True)\n        path = [1, 2]\n\n        with self.assertRaises(KeyError):\n            vul_checking(G, [path], \"invalid_type\")\n\n    def test_vul_checking_xss_multiple_rule_lists(self):\n        \"\"\"Test XSS vulnerability checking with multiple rule lists.\"\"\"\n        node_attrs = {\n            1: {\"funcid:int\": 100},\n            2: {\"funcid:int\": 200},\n            300: {\"tainted\": True},\n        }\n        edge_attrs = {(1, 2): {0: {\"type:TYPE\": \"OBJ_REACHES\", \"obj\": 300}}}\n        name_map = {100: \"handler\", 200: \"sink_hqbpillvul_http_write\"}\n        G = FakeGraphForVulChecking(\n            new_trace_rule=True,\n            node_attrs=node_attrs,\n            edge_attrs=edge_attrs,\n            name_map=name_map,\n            file_paths={1: \"/tmp/app.js\"},\n        )\n        path = [1, 2]\n\n        result = vul_checking(G, [path], \"xss\")\n        self.assertEqual(result, [path])\n\n    def test_vul_checking_xss_with_sanitizer(self):\n        \"\"\"Test XSS checking that should fail due to sanitizer.\"\"\"\n        node_attrs = {\n            1: {\"funcid:int\": 100},\n            2: {\"funcid:int\": 200},\n            300: {\"tainted\": True},\n        }\n        edge_attrs = {(1, 2): {0: {\"type:TYPE\": \"OBJ_REACHES\", \"obj\": 300}}}\n        name_map = {100: \"handler\", 200: \"sink_hqbpillvul_http_write\", 300: \"escapeHtml\"}\n        G = FakeGraphForVulChecking(\n            new_trace_rule=True,\n            node_attrs=node_attrs,\n            edge_attrs=edge_attrs,\n            name_map=name_map,\n            file_paths={1: \"/tmp/app.js\"},\n        )\n        path = [1, 2]\n\n        result = vul_checking(G, [path], \"xss\")\n        # Should not match because escapeHtml is a sanitizer\n        self.assertEqual(result, [])\n\n    def test_vul_checking_os_command(self):\n        \"\"\"Test OS command injection checking.\"\"\"\n        node_attrs = {\n            1: {\"funcid:int\": 100},\n            2: {\"funcid:int\": 200},\n            300: {\"tainted\": True},\n        }\n        edge_attrs = {(1, 2): {0: {\"type:TYPE\": \"OBJ_REACHES\", \"obj\": 300}}}\n        name_map = {100: \"handler\", 200: \"child_process.exec\"}\n        G = FakeGraphForVulChecking(\n            new_trace_rule=True,\n            node_attrs=node_attrs,\n            edge_attrs=edge_attrs,\n            name_map=name_map,\n            file_paths={1: \"/tmp/app.js\"},\n        )\n        path = [1, 2]\n\n        result = vul_checking(G, [path], \"os_command\")\n        self.assertEqual(result, [path])\n\n    def test_vul_checking_proto_pollution(self):\n        \"\"\"Test prototype pollution checking.\"\"\"\n        node_attrs = {\n            1: {\"funcid:int\": 100},\n            2: {\"funcid:int\": 200},\n            300: {\"tainted\": True},\n        }\n        edge_attrs = {(1, 2): {0: {\"type:TYPE\": \"OBJ_REACHES\", \"obj\": 300}}}\n        name_map = {100: \"handler\", 200: \"merge\"}\n        G = FakeGraphForVulChecking(\n            new_trace_rule=True,\n            node_attrs=node_attrs,\n            edge_attrs=edge_attrs,\n            name_map=name_map,\n        )\n        path = [1, 2]\n\n        result = vul_checking(G, [path], \"proto_pollution\")\n        self.assertEqual(result, [path])\n\n\nclass TestTraceback(unittest.TestCase):\n    def test_traceback_basic(self):\n        \"\"\"Test basic traceback functionality.\"\"\"\n        G = FakeGraphForVulChecking(\n            new_trace_rule=True,\n            node_attrs={\n                1: {\"type\": \"DUMMY_STMT\", \"funcid:int\": 100},\n                2: {\"type\": \"DUMMY_STMT\", \"funcid:int\": 200},\n            },\n            name_map={100: \"handler\", 200: \"child_process.exec\"},\n            parent_edges={\n                2: [(1, 2, {\"type:TYPE\": \"OBJ_REACHES\", \"obj\": 300})],\n            },\n            file_paths={1: \"/tmp/app.js\"},\n        )\n        G.get_node_by_attr = MagicMock(return_value=[2])\n\n        ret_paths, res_path, caller_list = traceback(G, \"os_command\")\n\n        self.assertIsInstance(ret_paths, list)\n        self.assertIsInstance(res_path, str)\n        self.assertIsInstance(caller_list, list)\n\n    def test_traceback_with_old_trace_rule(self):\n        \"\"\"Test traceback with old trace rule (new_trace_rule=False).\"\"\"\n        G = FakeGraphForVulChecking(\n            new_trace_rule=False,\n            node_attrs={\n                1: {\"type\": \"AST_CALL\", \"funcid:int\": 100},\n                2: {\"type\": \"AST_METHOD_CALL\", \"funcid:int\": 200},\n            },\n            name_map={100: \"handler\", 200: \"child_process.exec\"},\n            parent_edges={\n                2: [(1, 2, {\"type:TYPE\": \"OBJ_REACHES\", \"obj\": 300})],\n            },\n        )\n        G.get_node_by_attr = MagicMock(return_value=[1, 2])\n\n        ret_paths, res_path, caller_list = traceback(G, \"os_command\")\n\n        self.assertIsInstance(ret_paths, list)\n        self.assertIsInstance(res_path, str)\n\n\nif __name__ == \"__main__\":\n    unittest.main()\n"
}
