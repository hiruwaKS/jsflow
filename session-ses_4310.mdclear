00016| def eval_value(G: Graph, s: str, return_obj_node=False, ast_node=None):
00017|     """
00018|     Experimental. Extract Python values, JavaScript types from literal
00019|     values (presented by JavaScript code) and create object nodes.
00020| 
00021|     Args:
00022|         G (Graph): Graph.
00023|         s (str): The literal value (as JavaScript code).
00024|         return_obj_node (bool, optional): Create/return an object node
00025|             for the value. Defaults to False.
00026|         ast_node (optional): The value's AST node. Defaults to None.
00027| 
00028|     Returns:
00029|         evaluated, js_type, result: the Python value, JavaScript type
00030|             (in string), and object node (optional).
00031|     """
00032|     js_type = None
00033|     result = None
00034|     if s == "true":
00035|         evaluated = True
00036|         js_type = "boolean"
00037|         result = NodeHandleResult(name="true", obj_nodes=[G.true_obj])
00038|     elif s == "false":
00039|         evaluated = False
00040|         js_type = "boolean"
00041|         result = NodeHandleResult(name="false", obj_nodes=[G.false_obj])
00042|     elif s == "NaN":
00043|         evaluated = math.nan
00044|         js_type = "number"
00045|         result = NodeHandleResult(name="NaN", obj_nodes=[G.false_obj])
00046|     elif s == "Infinity":
00047|         evaluated = math.inf
00048|         js_type = "number"
00049|         result = NodeHandleResult(name="Infinity", obj_nodes=[G.infinity_obj])
00050|     elif s == "-Infinity":
00051|         evaluated = -math.inf
00052|         js_type = "number"
00053|         result = NodeHandleResult(name="-Infinity", obj_nodes=[G.negative_infinity_obj])
00054|     else:
00055|         evaluated = eval(s)
00056|         if isinstance(evaluated, (float, int)):
00057|             js_type = "number"
00058|         elif isinstance(evaluated, str):
00059|             js_type = "string"
00060|         if return_obj_node:
00061|             added_obj = G.add_obj_node(ast_node, js_type, s)
00062|             result = NodeHandleResult(obj_nodes=[added_obj])
00063|     if return_obj_node:
00064|         return evaluated, js_type, result
00065|     return evaluated, js_type
00066| 
00067| 
00068| def val_to_str(value, default=wildcard):
00069|     if type(value) in [float, int]:
