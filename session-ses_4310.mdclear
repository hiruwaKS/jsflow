00243|                 edge_data.append([])
00244|         except (ValueError, TypeError):
00245|             continue
00246|         for e in G.get_out_edges(name_node, edge_type="NAME_TO_OBJ"):
00247|             if value:
00248|                 elements[i].append(val_to_str(G.get_node_attr(e[1]).get("code")))
00249|             else:
