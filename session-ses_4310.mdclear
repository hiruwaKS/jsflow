00289| def is_wildcard_obj(G, obj):
00290|     attrs = G.get_node_attr(obj)
00291|     return (
00292|         (attrs.get("type") in ["object", "array"] and attrs.get("code") == wildcard)
00293|         or (attrs.get("type") in ["number", "string"] and attrs.get("code") == wildcard)
00294|         or attrs.get("type") == wildcard
