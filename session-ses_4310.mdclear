00105|     solver = None
00106|     symbols = None
00107| 
00108|     def symbol(obj):
00109|         """
00110|         Get or create a Z3 symbol for an object node.
00111| 
00112|         Creates a MixedSymbol (with both string and numeric views) for the object,
