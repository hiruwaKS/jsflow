00230| def to_python_array(G: Graph, array_obj, value=False):
00231|     elements = [[]]
00232|     edge_data = [[]]
00233|     for name_node in G.get_prop_name_nodes(array_obj):
00234|         name = G.get_node_attr(name_node).get("name")
00235|         if name in ("length", "__proto__"):
