  "content": "import unittest\nfrom unittest.mock import MagicMock, Mock, patch\nfrom collections import defaultdict\nimport sys\nimport os\n\nsys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))\n\nfrom jsflow.core.solver import MixedSymbol, check_number_operation, check_string_operation\n\n\nclass TestMixedSymbolExtended(unittest.TestCase):\n    \"\"\"Extended tests for MixedSymbol class.\"\"\"\n\n    def test_mixed_symbol_no_type(self):\n        \"\"\"Test MixedSymbol without type (creates both symbols).\"\"\"\n        sym = MixedSymbol(\"test\")\n        self.assertIsNotNone(sym.number())\n        self.assertIsNotNone(sym.string())\n\n    def test_mixed_symbol_number_type(self):\n        \"\"\"Test MixedSymbol with number type.\"\"\"\n        sym = MixedSymbol(\"test\", _type=\"number\")\n        self.assertIsNotNone(sym.number())\n        self.assertIsNone(sym.string())\n\n    def test_mixed_symbol_string_type(self):\n        \"\"\"Test MixedSymbol with string type.\"\"\"\n        sym = MixedSymbol(\"test\", _type=\"string\")\n        self.assertIsNone(sym.number())\n        self.assertIsNotNone(sym.string())\n\n\nclass TestCheckNumberOperationExtended(unittest.TestCase):\n    \"\"\"Extended tests for check_number_operation function.\"\"\"\n\n    def test_empty_array(self):\n        \"\"\"Test with empty array - should return True.\"\"\"\n        result = check_number_operation([])\n        self.assertTrue(result)\n\n    def test_all_number_symbols(self):\n        \"\"\"Test with all MixedSymbol objects having number type.\"\"\"\n        arr = [\n            MixedSymbol(\"1\", _type=\"number\"),\n            MixedSymbol(\"2\", _type=\"number\"),\n            MixedSymbol(\"3\", _type=\"number\"),\n        ]\n        result = check_number_operation(arr)\n        self.assertTrue(result)\n\n    def test_mixed_with_string_symbol(self):\n        \"\"\"Test with one string symbol - should return False.\"\"\"\n        arr = [\n            MixedSymbol(\"1\", _type=\"number\"),\n            MixedSymbol(\"2\", _type=\"string\"),\n        ]\n        result = check_number_operation(arr)\n        self.assertFalse(result)\n\n    def test_non_symbol_in_array(self):\n        \"\"\"Test with non-MixedSymbol object - should return False.\"\"\"\n        arr = [\n            MixedSymbol(\"1\", _type=\"number\"),\n            \"not a symbol\",\n            123,\n        ]\n        result = check_number_operation(arr)\n        self.assertFalse(result)\n\n    def test_single_number_symbol(self):\n        \"\"\"Test with single number symbol.\"\"\"\n        arr = [MixedSymbol(\"1\", _type=\"number\")]\n        result = check_number_operation(arr)\n        self.assertTrue(result)\n\n\nclass TestCheckStringOperationExtended(unittest.TestCase):\n    \"\"\"Extended tests for check_string_operation function.\"\"\"\n\n    def test_empty_array(self):\n        \"\"\"Test with empty array - should return True.\"\"\"\n        result = check_string_operation([])\n        self.assertTrue(result)\n\n    def test_all_string_symbols(self):\n        \"\"\"Test with all MixedSymbol objects having string type.\"\"\"\n        arr = [\n            MixedSymbol(\"1\", _type=\"string\"),\n            MixedSymbol(\"2\", _type=\"string\"),\n        ]\n        result = check_string_operation(arr)\n        self.assertTrue(result)\n\n    def test_mixed_with_number_symbol(self):\n        \"\"\"Test with one number symbol - should return False.\"\"\"\n        arr = [\n            MixedSymbol(\"1\", _type=\"string\"),\n            MixedSymbol(\"2\", _type=\"number\"),\n        ]\n        result = check_string_operation(arr)\n        self.assertFalse(result)\n\n    def test_non_symbol_in_array(self):\n        \"\"\"Test with non-MixedSymbol object - should return False.\"\"\"\n        arr = [\n            MixedSymbol(\"1\", _type=\"string\"),\n            None,\n            [],\n        ]\n        result = check_string_operation(arr)\n        self.assertFalse(result)\n\n    def test_single_string_symbol(self):\n        \"\"\"Test with single string symbol.\"\"\"\n        arr = [MixedSymbol(\"1\", _type=\"string\")]\n        result = check_string_operation(arr)\n        self.assertTrue(result)\n\n\nclass TestMixedSymbolSymbolNames(unittest.TestCase):\n    \"\"\"Test that MixedSymbol creates proper z3 symbol names.\"\"\"\n\n    def test_symbol_name_format(self):\n        \"\"\"Test that symbol names are correctly formatted.\"\"\"\n        sym = MixedSymbol(\"node123\")\n        # The z3 symbols should have names like \"nnode123\" and \"snode123\"\n        num = sym.number()\n        str_sym = sym.string()\n        if num is not None:\n            self.assertIn(\"node123\", str(num))\n        if str_sym is not None:\n            self.assertIn(\"node123\", str(str_sym))\n\n\nclass TestEdgeCases(unittest.TestCase):\n    \"\"\"Test edge cases for solver functions.\"\"\"\n\n    def test_check_number_operation_with_none_type_symbols(self):\n        \"\"\"Test check_number_operation with symbols that have no type.\"\"\"\n        arr = [\n            MixedSymbol(\"1\"),  # No type specified\n        ]\n        # With no type, both symbols are created, so number() should not be None\n        result = check_number_operation(arr)\n        self.assertTrue(result)\n\n    def test_check_string_operation_with_none_type_symbols(self):\n        \"\"\"Test check_string_operation with symbols that have no type.\"\"\"\n        arr = [\n            MixedSymbol(\"1\"),  # No type specified\n        ]\n        # With no type, both symbols are created, so string() should not be None\n        result = check_string_operation(arr)\n        self.assertTrue(result)\n\n    def test_mixed_symbol_string_type_has_no_number(self):\n        \"\"\"Verify string-type MixedSymbol has None for number().\"\"\"\n        sym = MixedSymbol(\"test\", _type=\"string\")\n        self.assertIsNone(sym.number())\n        self.assertIsNotNone(sym.string())\n\n    def test_mixed_symbol_number_type_has_no_string(self):\n        \"\"\"Verify number-type MixedSymbol has None for string().\"\"\"\n        sym = MixedSymbol(\"test\", _type=\"number\")\n        self.assertIsNotNone(sym.number())\n        self.assertIsNone(sym.string())\n\n\nif __name__ == \"__main__\":\n    unittest.main()\n"
}
