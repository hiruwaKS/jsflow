{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Python Jsflow on test.js",
            "type": "debugpy",
            "request": "launch",
            "module": "jsflow",
            "cwd": "${workspaceFolder}/",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/jsflow"
            },
            "args": [
                "-p",
                "tmp/test.js"
            ],
            "console": "integratedTerminal",
        },
        {
            "name": "Python: Run Benchmark",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/evaluation/run_bench.py",
            "cwd": "${workspaceFolder}",
        }
    ]
}