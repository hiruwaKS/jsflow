    "version": "0.2.0",
    "configurations": [

        {
            "name": "Pythonjsflow",
            "type": "python",
            "request": "launch",
            "module": "jsflow",
            "cwd": "${workspaceFolder}/",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/jsflow"
